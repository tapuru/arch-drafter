{
  "name": "@bc-arch-drafter",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "dev:web-client": "pnpm --filter \"web-client\" run dev",
    "dev:api": "concurrently \"pnpm:dev:api:*\"",
    "dev:api:gateway": "pnpm --filter @bc-arch-drafter/gateway start:dev",
    "dev:api:projects": "pnpm --filter @bc-arch-drafter/projects-service start:dev",
    "dev:api:sessions": "pnpm --filter @bc-arch-drafter/sessions-service start:dev",
    "dev:api:export": "pnpm --filter @bc-arch-drafter/export-service start:dev",
    "dev:api:storage": "pnpm --filter @bc-arch-drafter/storage-service start:dev",
    "lint": "pnpm -r run lint",
    "dev:api:users": "pnpm --filter @bc-arch-drafter/users-service start:dev",
    "dev:api:db": "pnpm --filter @bc-arch-drafter/db start:dev",
    "lint:uncache": "find . -name .eslintcache ! -path '*/node_modules/*' | xargs rm -f",
    "format:lint": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:packages": "pnpm -r --filter \"./packages/*\" run build",
    "build:gateway": "pnpm -r --filter \"./packages/*\" run build",
    "build:watch:model": "pnpm --filter \"@bc-arch-drafter/model\" run build:watch",
    "build:watch:ui": "pnpm --filter \"@bc-arch-drafter/shared-ui\" run build:watch",
    "build:watch:contracts": "pnpm --filter \"@bc-arch-drafter/contracts\" run build:watch",
    "build:watch:lib": "pnpm --filter \"@bc-arch-drafter/lib\" run build:watch",
    "build:watch:auth": "pnpm --filter \"@bc-arch-drafter/auth\" run build:watch",
    "web-client:dev": "pnpm --filter \"web-client\" run dev",
    "build:watch:postgres-db": "pnpm --filter \"@bc-arch-drafter/postgres-db\" run build:watch",
    "build:watch:api-config": "pnpm --filter \"@bc-arch-drafter/api-config\" run build:watch",
    "build:watch": "concurrently \"pnpm:build:watch:*\""
  },
  "devDependencies": {
    "@jest/types": "^30.0.5",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/parser": "^8.38.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-unicorn": "^60.0.0",
    "globals": "^16.0.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "prettier": "^3.6.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0"
  },
  "private": true,
  "description": "web application that allows customers and architects work together to build a starter plan draft",
  "dependencies": {
    "@babel/runtime": "^7.28.2",
    "@radix-ui/primitive": "^1.1.2",
    "@radix-ui/react-compose-refs": "^1.1.2",
    "@radix-ui/react-context": "^1.1.2",
    "@radix-ui/react-presence": "^1.1.4",
    "@radix-ui/react-primitive": "^2.1.3",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@radix-ui/react-use-effect-event": "^0.0.2",
    "@radix-ui/react-use-layout-effect": "^1.1.1",
    "@radix-ui/react-use-previous": "^1.1.1",
    "@radix-ui/react-use-size": "^1.1.1",
    "scheduler": "^0.26.0"
  }
}
